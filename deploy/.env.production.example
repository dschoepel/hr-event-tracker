# Copy to /data/__APP_NAME__/.env.production on the VPS (never commit with real values)
APP_PORT=3000
TZ=America/Chicago

# Run container as host user (avoids data volume permission issues)
# Find your UID/GID on the VPS with: id $(whoami)
PUID=1000
PGID=1000

# --- Tier 2 (PostgreSQL) ---
# DATABASE_URL=postgresql://user:pass@db:5432/__APP_NAME__
# POSTGRES_USER=app
# POSTGRES_PASSWORD=<secure password>
# POSTGRES_DB=__APP_NAME__

# Auth.js
# AUTH_SECRET=<openssl rand -base64 32>
# AUTH_URL=https://yourdomain.com
# AUTH_TRUST_HOST=true
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# ADMIN_EMAILS=you@example.com

# --- Tier 3 (Supabase) ---
# NEXT_PUBLIC_SUPABASE_URL=https://supabase.yourdomain.com
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
